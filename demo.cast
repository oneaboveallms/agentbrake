[103.363994, "o", "AgentBrake knows 52 destructive patterns:\r\n\r\nв”Ђв”Ђ cloud в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\r\n  рџ”ґ AWS_S3_REMOVE_BUCKET           Force deletes an S3 bucket and all its contents\r\n  рџ”ґ AWS_RDS_DELETE                 Deletes an RDS database instance\r\n  рџ”ґ RAILWAY_VOLUME_DELETE          Deletes a Railway volume (caused PocketOS disaster)\r\n  рџ”ґ AWS_DYNAMODB_DELETE_TABLE      Deletes a DynamoDB table and all its data\r\n  рџџЎ AWS_EC2_TERMINATE              Terminates EC2 instances (cannot be undone)\r\n  рџ”ґ AWS_IAM_DELETE_USER            Deletes an IAM user account\r\n  рџ”ґ AWS_CLOUDFORMATION_DELETE      Deletes a CloudFormation stack and all its resources\r\n"]
